static func get_tile_cell(map_value: int) -> TileConfig.TileCell:
	match map_value:
		1:
			return TileConfig.brick_wall
		2:
			return TileConfig.steel_wall
		3:
			return TileConfig.forest
		4:
			return TileConfig.water
		5:
			return TileConfig.ice
		_:
			return null

static func load_level(level_index: int) -> void:
	if level_index < 0 or level_index >= MAP_DATA.size():
		push_error("Invalid level index: %d" % level_index)
		return

	TileHelper.clear_grid()
	var level_data: Array = MAP_DATA[level_index]
	for y in range(mini(level_data.size(), MAP_HEIGHT)):
		var row: Array = level_data[y]
		for x in range(mini(row.size(), MAP_WIDTH)):
			var map_value: int = row[x]
			var grid := Vector2i(x, y)
			if map_value == 0:
				continue
			var tile_cell := get_tile_cell(map_value)
			if tile_cell != null:
				TileHelper.create_tile(tile_cell, grid)
